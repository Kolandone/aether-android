<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_primary">

    <!-- Header -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center_vertical"
        android:padding="16dp" android:background="@color/bg_secondary">
        <TextView android:layout_width="0dp" android:layout_height="wrap_content" android:layout_weight="1"
            android:text="⚡ Aether" android:textColor="@color/text_primary" android:textSize="20sp" android:textStyle="bold"/>
        <TextView android:id="@+id/tvVersion" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:textColor="@color/text_secondary" android:textSize="10sp"/>
    </LinearLayout>

    <!-- Links -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center" android:paddingVertical="8dp">
        <TextView android:id="@+id/tvTelegram" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="✈ Telegram" android:textColor="@color/accent" android:textSize="11sp"
            android:clickable="true" android:focusable="true" android:padding="8dp"/>
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="•" android:textColor="@color/border" android:textSize="11sp"/>
        <TextView android:id="@+id/tvGithub" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚙ GitHub" android:textColor="@color/accent" android:textSize="11sp"
            android:clickable="true" android:focusable="true" android:padding="8dp"/>
    </LinearLayout>

    <!-- Center area with weight -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="0dp"
        android:layout_weight="1" android:orientation="vertical" android:gravity="center">

        <!-- Status -->
        <TextView android:id="@+id/tvStatus" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Disconnected" android:textColor="@color/text_secondary" android:textSize="14sp"
            android:layout_marginBottom="24dp"/>

        <!-- Connect Button -->
        <FrameLayout android:id="@+id/btnCircle" android:layout_width="120dp" android:layout_height="120dp"
            android:layout_gravity="center" android:layout_marginBottom="24dp"
            android:clickable="true" android:focusable="true">
            <View android:id="@+id/btnBg" android:layout_width="120dp" android:layout_height="120dp"
                android:background="@drawable/circle_disconnected"/>
            <ImageView android:id="@+id/btnIcon" android:layout_width="48dp" android:layout_height="48dp"
                android:layout_gravity="center" android:src="@drawable/ic_power"/>
        </FrameLayout>

        <!-- Protocol Selector -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Protocol" android:textColor="@color/text_secondary" android:textSize="11sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:gravity="center">
            <TextView android:id="@+id/btnMasque" android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="MASQUE" android:textSize="12sp" android:textStyle="bold"
                android:gravity="center" android:paddingHorizontal="16dp"
                android:background="@drawable/chip_selected" android:textColor="@color/text_primary"
                android:clickable="true" android:focusable="true" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/btnWireguard" android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="WireGuard" android:textSize="12sp" android:textStyle="bold"
                android:gravity="center" android:paddingHorizontal="16dp"
                android:background="@drawable/chip_unselected" android:textColor="@color/text_secondary"
                android:clickable="true" android:focusable="true" android:layout_marginEnd="8dp"/>
            <TextView android:id="@+id/btnGool" android:layout_width="wrap_content" android:layout_height="36dp"
                android:text="Gool" android:textSize="12sp" android:textStyle="bold"
                android:gravity="center" android:paddingHorizontal="16dp"
                android:background="@drawable/chip_unselected" android:textColor="@color/text_secondary"
                android:clickable="true" android:focusable="true"/>
        </LinearLayout>
    </LinearLayout>

    <!-- Bottom nav -->
    <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal" android:gravity="center" android:paddingVertical="12dp">
        <TextView android:id="@+id/btnLogs" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="📋 Logs" android:textColor="@color/accent" android:textSize="12sp"
            android:clickable="true" android:focusable="true" android:padding="12dp"/>
        <TextView android:id="@+id/btnSettings" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="⚙ Settings" android:textColor="@color/accent" android:textSize="12sp"
            android:clickable="true" android:focusable="true" android:padding="12dp"/>
        <TextView android:id="@+id/btnAbout" android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="ℹ About" android:textColor="@color/accent" android:textSize="12sp"
            android:clickable="true" android:focusable="true" android:padding="12dp"/>
    </LinearLayout>

</LinearLayout>
